# TenderBoard product modes:
# - mock: local product flow, no real CROO calls
# - dry-run: real app path without calling CROO payOrder
# - live: real CROO SDK path; requires credentials and explicit payment approval
TENDERBOARD_MODE=mock
TENDERBOARD_PORT=4174
TENDERBOARD_MAX_PAYMENT_USDC=0.25
TENDERBOARD_RECEIPTS_DIR=data/runs

# true = server runs requester + worker SDK clients in one process.
# false = run the worker separately with `npm run worker`.
TENDERBOARD_EMBED_WORKER=true

# CROO endpoints. Required for live mode.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# Requester/task-giver agent SDK key. Required for live mode.
CROO_REQUESTER_SDK_KEY=croo_sk_replace_me

# Worker/provider agent SDK key and registered service id. Required for live mode.
CROO_WORKER_SDK_KEY=croo_sk_replace_me
CROO_WORKER_SERVICE_ID=svc_replace_me

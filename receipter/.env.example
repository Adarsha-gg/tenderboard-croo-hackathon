# Receipter is Sui-native:
# - sui-dev: local operator flow that still produces Sui-shaped work orders and anchor plans
# - sui: requires Sui package, registry, operator address, and Walrus endpoints
RECEIPTER_MODE=sui-dev
RECEIPTER_PORT=4174
RECEIPTER_MAX_PAYMENT_SUI=0.050
RECEIPTER_RECEIPTS_DIR=data/runs
RECEIPTER_WORKER_AGENT_ID=sui_opportunity_scout

SUI_NETWORK=testnet
SUI_OPERATOR_ADDRESS=
SUI_PACKAGE_ID=
SUI_RECEIPT_REGISTRY_ID=
SUI_AGENT_PASSPORT_ID=
SUI_CLI_PATH=
SUI_CLIENT_CONFIG=

WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
